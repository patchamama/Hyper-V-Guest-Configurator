{
  "_info": "Community scraper configuration. Adapt selectors to the target site DOM. This file is generic — copy and modify for other community sites.",
  "enabled": true,
  "name": "ELO Community",
  "icon": "🏢",
  "auth": {
    "loginUrl": "https://community.elo.com/",
    "selectors": {
      "usernameField": "input[name='username']",
      "passwordField": "input[name='password']",
      "submitButton": "button[type='submit'][data-test-id='button-sign_in'], button[type='submit']",
      "loggedInIndicator": ".navbar-item.has-dropdown .navbar-link, [data-test='user-menu'], .user-menu, a[href*='/profile']"
    }
  },
  "board": {
    "url": "https://community.elo.com/community/plugin/de.elo.ix.plugin.proxy/wf/apps/app/sol.knowledge.apps.KnowledgeBoard/#/?board=COMMUNITY&page=1",
    "waitForSelector": "sol-board, sol-knowledge-board, .board-wrapper, [class*='board-content'], [class*='section']",
    "waitTimeout": 20000,
    "selectors": {
      "sectionItems": "sol-board-entry, [class*='section-entry'], .board-entry, [data-section]",
      "sectionTitle": "h2, h3, [class*='title'], [class*='name'], [class*='entry-name']",
      "sectionLink": "a[href]:not([href*='logout']):not([href*='profile'])",
      "articleItems": "[class*='article-item'], sol-article-item, [data-article-id]",
      "articleLink": "a[href]",
      "articleTitle": "h1, [class*='article-title']",
      "articleBody": "[class*='content'], .ql-editor, [class*='article-content'], [class*='article-body']",
      "articleDate": "time, [datetime], [class*='date'], [class*='created']",
      "articleAuthor": "[class*='by'], [class*='author'], [class*='user'], sol-user-display",
      "articleTags": "[class*='label'], [class*='tag'], .tag-item",
      "paginationNext": "button[aria-label='Next'], a[aria-label*='next'], .pagination-next, button.next-page"
    }
  },
  "output": {
    "dir": "community",
    "format": "markdown",
    "downloadImages": true,
    "delayBetweenArticles": 1500,
    "delayBetweenPages": 2000,
    "delayBetweenSections": 3000,
    "overwriteExisting": false,
    "maxArticlesPerSection": 0
  },
  "elasticsearch": {
    "enabled": false,
    "host": "http://localhost:9200",
    "index": "community-articles",
    "username": "",
    "password": "",
    "model": "mE5-small",
    "modelHfId": "Xenova/multilingual-e5-small",
    "dimensions": 384,
    "batchSize": 16
  }
}